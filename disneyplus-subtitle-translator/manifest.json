{
  "manifest_version": 3,
  "name": "Disney+ Subtitle Translator",
  "version": "1.0.0",
  "description": "Translate Disney+ subtitles in real-time. Supports bilingual subtitles, custom styling, and multiple translation engines (Google, Gemini, DeepL).",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.disneyplus.com/*",
    "https://translate.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.deepl.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.disneyplus.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
